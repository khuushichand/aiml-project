# Minimal .env for tldw_server quickstart
# See .env.template for full configuration options
#
# Usage:
#   cp .env.quickstart .env
#   # Edit SINGLE_USER_API_KEY below
#   python -m tldw_Server_API.app.core.AuthNZ.initialize --non-interactive
#   uvicorn tldw_Server_API.app.main:app

# Required: Authentication mode (single_user or multi_user)
AUTH_MODE=single_user

# Required: Your API key (minimum 16 characters, must be changed!)
SINGLE_USER_API_KEY=CHANGE-ME-to-a-secure-key-at-least-16-chars

# Database (SQLite default, no setup required)
DATABASE_URL=sqlite:///./Databases/users.db

# Optional: Add an LLM provider key to enable chat completions
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
