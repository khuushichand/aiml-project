# ================================================
# tldw_server API Keys Configuration Template
# ================================================
# Canonical tldw_server environment template
# Copy to tldw_Server_API/Config_Files/.env and set secure values.

# Mode: single_user (API key) or multi_user (JWT)
AUTH_MODE=single_user

# Single-user API key (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SINGLE_USER_API_KEY=CHANGE_ME_TO_SECURE_API_KEY

# Multi-user JWT secret (required if AUTH_MODE=multi_user)
# Minimum 32 chars; generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY_MIN_32_CHARS

# Session encryption key (Fernet) - optional; if blank, it will be generated
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# Database (SQLite default). For Postgres in multi-user prod:
# DATABASE_URL=postgresql://tldw_user:StrongPass@localhost:5432/tldw_users
DATABASE_URL=sqlite:///./Databases/users.db

MCP_JWT_SECRET=CHANGE_ME_TO_SECURE_MCP_JWT_SECRET
MCP_API_KEY_SALT=CHANGE_ME_TO_SECURE_MCP_API_KEY_SALT

# ================================================
# tldw_Server Frontend Settings
# ================================================
# NextJS Front-End API Key
NEXT_PUBLIC_X_API_KEY=CHANGE_ME_TO_UNIQUE_FRONTEND_KEY

# CORS allowed origins for browser clients (comma-separated)
#ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:8080,http://192.168.5.160:3001,
DISABLE_CORS=false
CORS_ALLOW_CREDENTIALS=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# ================================================
# LLM Provider API Keys
# ================================================
# OpenAI - For GPT models
OPENAI_API_KEY=

# Anthropic - For Claude models
ANTHROPIC_API_KEY=

# Cohere - For Command models
COHERE_API_KEY=

# Google - For Gemini models
GOOGLE_API_KEY=

# Groq - For fast inference with open models
GROQ_API_KEY=

# DeepSeek - For DeepSeek models
DEEPSEEK_API_KEY=

# Mistral - For Mistral models
MISTRAL_API_KEY=

# HuggingFace - For HuggingFace models
HUGGINGFACE_API_KEY=

# OpenRouter - For routing to multiple providers
OPENROUTER_API_KEY=

# QwenAPI - For routing to multiple providers
QWEN_API_KEY=

MOONSHOT_API_KEY=

# ================================================
# Text-to-Speech API Keys
# ================================================
# ElevenLabs - For TTS services
ELEVENLABS_API_KEY=

# ================================================
# Custom/Local LLM API Keys
# ================================================
# Custom OpenAI-compatible endpoint #1
CUSTOM_OPENAI_API_KEY=${OPENAI_API_KEY}

# Custom OpenAI-compatible endpoint #2
CUSTOM_OPENAI2_API_KEY=${OPENAI_API_KEY}

# ================================================
# Local Model API Keys (usually not needed)
# ================================================
# Kobold API (typically no key required)
KOBOLD_API_KEY=

# Llama.cpp API (typically no key required)
LLAMA_API_KEY=

# Oobabooga API (typically no key required)
OOBA_API_KEY=

# TabbyAPI (typically no key required)
TABBY_API_KEY=

# vLLM API (typically no key required)
VLLM_API_KEY=

# Ollama API (typically no key required)
OLLAMA_API_KEY=

# Aphrodite API (typically no key required)
APHRODITE_API_KEY=

# ================================================
# Search Engine API Keys
# ================================================
# Bing Search API
BING_SEARCH_API_KEY=

# Brave Search API
BRAVE_SEARCH_API_KEY=
BRAVE_AI_API_KEY=

# Google Custom Search
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Kagi Search API
KAGI_API_KEY=

# Tavily Search API
TAVILY_API_KEY=

# Serper Search API
SERPER_API_KEY=

# Baidu Search API
BAIDU_API_KEY=

# Yandex Search API
YANDEX_API_KEY=
YANDEX_SEARCH_ID=

# ================================================
# Web Scraping API Keys
# ================================================
WEB_SCRAPER_API_KEY=

# ================================================
# Embedding Service API Keys
# ================================================
# For remote embedding services
EMBEDDING_API_KEY=

# ================================================
# MCP Unified WebSocket security (allowed origins)
# ================================================
# JSON list of trusted Origins for MCP WS clients.
# Include your local UI ports and any dev frontend (e.g., Vite on 5173).
MCP_WS_AUTH_REQUIRED=true
MCP_WS_ALLOWED_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000","http://localhost:5173"]

# ================================================
# Vector Database API Keys
# ================================================
# For remote vector DB services
VECTOR_DB_API_KEY=

# In production environments, set:
# tldw_production=true
# SHOW_API_KEY_ON_STARTUP=false

# ================================================
# Unified Streaming (SSE/WS) Tuning
# ================================================
# Use unified streams by enabling STREAMS_UNIFIED=1 (optional; off by default)
# STREAMS_UNIFIED=1
# Prefer data-mode heartbeats behind proxies/CDNs
STREAM_HEARTBEAT_MODE=data
# Heartbeat cadence in seconds
STREAM_HEARTBEAT_INTERVAL_S=10
# Bounded queue size for SSE backpressure (increase for very chatty models)
STREAM_QUEUE_MAXSIZE=512

# By default, provider control lines (event:/id:/retry:) are dropped.
# Set to 1 to preserve control lines for debugging or specific clients.
# STREAM_PROVIDER_CONTROL_PASSTHRU=1

# Prefer native HTTP adapter for DeepSeek (stabilizes streaming in tests)
LLM_ADAPTERS_NATIVE_HTTP_DEEPSEEK=1

# ================================================
# QUICK START INSTRUCTIONS
# ================================================
# 1. Copy this template:
#    cp tldw_Server_API/Config_Files/.env.example tldw_Server_API/Config_Files/.env
#
# 2. Add your API keys to the .env file:
#    nano .env  # or use your preferred editor
#
# 3. Ensure .env is not tracked by git:
#    git status  # Should NOT show .env file
#
# 4. Run the migration script (if upgrading from config.txt):
#    python migrate_api_keys.py
#
# ================================================
# NOTES
# ================================================
# - API keys in this file override those in config.txt
# - Environment variables override both .env and config.txt
# - Keep this file secure and never share it
# - Most local model APIs don't require API keys
# - You only need to fill in keys for services you use
# ================================================
CUSTOM_OPENAI_API_2_API_KEY=${OPENAI_API_KEY}
BEDROCK_API_BASE_URL=https://api.openai.com
BEDROCK_API_KEY=${OPENAI_API_KEY}
MLX_MODEL_PATH=Qwen/Qwen3-0.6B-MLX-4bit
OTEL_METRICS_EXPORTER=prometheus
