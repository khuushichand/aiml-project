# ================================================
# tldw_server Environment Configuration Template
# ================================================
# Copy to tldw_Server_API/Config_Files/.env and set the REQUIRED values.
#
# Precedence: Environment variables > .env file > config.txt
# You only need to fill in keys for services you actually use.
#
# Docker quickstart note: If using `make quickstart`, the Docker entrypoint
# auto-generates SINGLE_USER_API_KEY and MCP secrets if they are missing or
# set to placeholder values. You can retrieve the key with `make show-api-key`.

# ================================================
# REQUIRED — Set these before first run
# ================================================

# Auth mode: "single_user" (API key) or "multi_user" (JWT)
AUTH_MODE=single_user

# Single-user API key (min 16 chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SINGLE_USER_API_KEY=CHANGE_ME_TO_SECURE_API_KEY

# ================================================
# REQUIRED FOR MULTI-USER MODE ONLY
# ================================================
# Uncomment and set these if AUTH_MODE=multi_user

# JWT secret (min 32 chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
#JWT_SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY_MIN_32_CHARS

# Database URL — SQLite for dev, Postgres for production multi-user
# SQLite:    sqlite:///./Databases/users.db
# Postgres:  postgresql://tldw_user:StrongPass@localhost:5432/tldw_users
DATABASE_URL=sqlite:///./Databases/users.db

# Session encryption key (Fernet) — auto-generated if blank
#SESSION_ENCRYPTION_KEY=

# ================================================
# OPTIONAL — LLM Provider Keys
# ================================================
# Set at least one to use Chat features.
# Leave blank for providers you don't use.

# OpenAI — GPT models
OPENAI_API_KEY=

# Anthropic — Claude models
ANTHROPIC_API_KEY=

# Google — Gemini models
GOOGLE_API_KEY=

# Cohere — Command models
COHERE_API_KEY=

# Groq — Fast inference with open models
GROQ_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Mistral
MISTRAL_API_KEY=

# HuggingFace
HUGGINGFACE_API_KEY=

# OpenRouter — Multi-provider routing
OPENROUTER_API_KEY=

# Qwen
QWEN_API_KEY=

# Moonshot
MOONSHOT_API_KEY=

# ================================================
# OPTIONAL — Text-to-Speech Keys
# ================================================

# ElevenLabs
ELEVENLABS_API_KEY=

# ================================================
# OPTIONAL — Custom/Local LLM Endpoints
# ================================================
# These typically don't require API keys for local setups.

# Custom OpenAI-compatible endpoints
CUSTOM_OPENAI_API_KEY=${OPENAI_API_KEY}
CUSTOM_OPENAI2_API_KEY=${OPENAI_API_KEY}
CUSTOM_OPENAI_API_2_API_KEY=${OPENAI_API_KEY}

# Local model APIs (typically no key required)
KOBOLD_API_KEY=
LLAMA_API_KEY=
OOBA_API_KEY=
TABBY_API_KEY=
VLLM_API_KEY=
OLLAMA_API_KEY=
APHRODITE_API_KEY=

# Bedrock
BEDROCK_API_BASE_URL=https://api.openai.com
BEDROCK_API_KEY=${OPENAI_API_KEY}

# MLX (Apple Silicon)
MLX_MODEL_PATH=Qwen/Qwen3-0.6B-MLX-4bit

# ================================================
# OPTIONAL — Search Engine Keys
# ================================================

BING_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY=
BRAVE_AI_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
KAGI_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
BAIDU_API_KEY=
YANDEX_API_KEY=
YANDEX_SEARCH_ID=

# ================================================
# OPTIONAL — Web Scraping
# ================================================

WEB_SCRAPER_API_KEY=

# ================================================
# OPTIONAL — Embedding & Vector DB
# ================================================

EMBEDDING_API_KEY=
VECTOR_DB_API_KEY=

# ================================================
# OPTIONAL — Frontend / CORS
# ================================================

# NOTE: NEXT_PUBLIC_X_API_KEY is for the frontend admin API,
# NOT the same as SINGLE_USER_API_KEY used for backend API access.
# Only needed in advanced (non-proxy) deployment mode.
NEXT_PUBLIC_X_API_KEY=CHANGE_ME_TO_UNIQUE_FRONTEND_KEY

# Browser CORS — defaults work for localhost. Set ALLOWED_ORIGINS when
# your browser UI runs from a different origin.
DISABLE_CORS=false
CORS_ALLOW_CREDENTIALS=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# ================================================
# OPTIONAL — MCP Security
# ================================================
# Auto-generated by Docker entrypoint. Set explicitly for shared/production deployments.
# Min 32 chars each.

MCP_JWT_SECRET=CHANGE_ME_TO_SECURE_MCP_JWT_SECRET
MCP_API_KEY_SALT=CHANGE_ME_TO_SECURE_MCP_API_KEY_SALT

# MCP WebSocket allowed origins
MCP_WS_AUTH_REQUIRED=true
MCP_WS_ALLOWED_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000","http://localhost:5173"]

# ================================================
# OPTIONAL — Streaming Tuning
# ================================================

# Unified streams (off by default)
#STREAMS_UNIFIED=1
STREAM_HEARTBEAT_MODE=data
STREAM_HEARTBEAT_INTERVAL_S=10
STREAM_QUEUE_MAXSIZE=512
#STREAM_PROVIDER_CONTROL_PASSTHRU=1

# Native HTTP adapter for DeepSeek
LLM_ADAPTERS_NATIVE_HTTP_DEEPSEEK=1

# ================================================
# OPTIONAL — Production Settings
# ================================================

# In production environments, set:
#tldw_production=true
#SHOW_API_KEY_ON_STARTUP=false
OTEL_METRICS_EXPORTER=prometheus
