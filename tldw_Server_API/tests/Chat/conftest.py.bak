@pytest.fixture(autouse=True)
async def setup_test_environment(test_db_pool, mock_media_db, mock_chacha_db):
    """Set up the test environment with proper database overrides."""
    from tldw_Server_API.app.api.v1.API_Deps.DB_Deps import get_media_db_for_user
    from tldw_Server_API.app.api.v1.API_Deps.ChaCha_Notes_DB_Deps import get_chacha_db_for_user
    from tldw_Server_API.app.core.AuthNZ.database import get_db_pool
    
    # Override database pool
    app.dependency_overrides[get_db_pool] = lambda: test_db_pool
    
    # Override media database
    app.dependency_overrides[get_media_db_for_user] = lambda: mock_media_db
    
    # Override chacha database  
    app.dependency_overrides[get_chacha_db_for_user] = lambda: mock_chacha_db
    
    yield
    
    # Cleanup overrides
    app.dependency_overrides.clear()


# Helper functions for tests

def get_auth_headers(token: str) -> dict:
    """Get authentication headers for requests."""
    settings = get_settings()
    
    if settings.AUTH_MODE == "multi_user":
        return {"Authorization": token}
    else:
        return {"X-API-Key": token}


async def create_test_user(db_pool: DatabasePool, username: str, password: str, email: str = None):
    """Helper to create additional test users."""
    from tldw_Server_API.app.core.AuthNZ.models import User
    
    password_service = get_password_service()
    hashed_password = password_service.hash_password(password)
    
    async with db_pool.get_session() as session:
        user = User(
            username=username,
            email=email or f"{username}@test.com",
            hashed_password=hashed_password,
            is_active=True,
            is_verified=True,
            created_at=datetime.datetime.utcnow(),
            updated_at=datetime.datetime.utcnow()
        )
        
        session.add(user)
        await session.commit()
        await session.refresh(user)
        
        return user


async def login_user(client: TestClient, username: str, password: str) -> str:
    """Helper to login a user and get an access token."""
    response = client.post(
        "/api/v1/auth/login",
        json={"username": username, "password": password}
    )
    
    if response.status_code == 200:
        return response.json()["access_token"]
    else:
        raise Exception(f"Login failed: {response.text}")