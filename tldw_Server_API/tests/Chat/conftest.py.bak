@pytest.fixture(scope="session")
async def test_db_pool(test_db_path):
    """Create a test database pool with tables initialized."""
    # Create test database URL
    test_db_url = f"sqlite:///{test_db_path}"
    
    # Create a test settings object
    test_settings = Settings(
        AUTH_MODE="multi_user",
        DATABASE_URL=test_db_url,
        JWT_SECRET_KEY=os.getenv("JWT_SECRET_KEY", "test-secret-key-for-testing"),
        ALLOW_REGISTRATION=True
    )
    
    # Initialize database pool
    db_pool = DatabasePool(test_settings)
    await db_pool.initialize()
    
    # Create tables
    async with db_pool.get_session() as session:
        # Import models to ensure they're registered
        from tldw_Server_API.app.core.AuthNZ.models import Base, User, RefreshToken
        
        # Create all tables
        async with session.begin():
            # For SQLite, we need to use the sync engine
            await session.run_sync(Base.metadata.create_all)
    
    yield db_pool
    
    # Cleanup
    await db_pool.close()


@pytest.fixture(scope="session")
async def test_user(test_db_pool):
    """Create a test user in the database."""
    from tldw_Server_API.app.core.AuthNZ.models import User
    
    password_service = get_password_service()
    hashed_password = password_service.hash_password(TEST_USER_PASSWORD)
    
    async with test_db_pool.get_session() as session:
        # Check if user already exists
        from sqlalchemy import select
        result = await session.execute(
            select(User).where(User.username == TEST_USER_USERNAME)
        )
        existing_user = result.scalar_one_or_none()
        
        if existing_user:
            return existing_user
        
        # Create new user
        user = User(
            username=TEST_USER_USERNAME,
            email=TEST_USER_EMAIL,
            hashed_password=hashed_password,
            is_active=True,
            is_verified=True,
            created_at=datetime.datetime.utcnow(),
            updated_at=datetime.datetime.utcnow()
        )
        
        session.add(user)
        await session.commit()
        await session.refresh(user)
        
        return user


@pytest.fixture
async def auth_token(test_user):
    """Generate a valid JWT token for the test user."""
    jwt_service = get_jwt_service()
    
    # Create access token
    token_data = {
        "sub": str(test_user.id),
        "username": test_user.username,
        "email": test_user.email,
        "type": "access"
    }
    
    access_token = jwt_service.create_access_token(token_data)
    return f"Bearer {access_token}"


@pytest.fixture
async def authenticated_client(auth_token):
    """Create a test client with authentication headers."""
    with TestClient(app) as client:
        # Get CSRF token
        response = client.get("/api/v1/health")
        csrf_token = response.cookies.get("csrf_token", "")
        
        # Set up headers
        client.headers = {
            "Authorization": auth_token,
            "X-CSRF-Token": csrf_token
        }
        client.cookies = {"csrf_token": csrf_token}
        
        yield client


