{
  "name": "pipeline_l2_acp",
  "version": 1,
  "description": "Domain-only ACP pipeline (L2): requirements, plan, implementation, and implementation review gate.",
  "tags": [
    "acp",
    "pipeline",
    "domain",
    "l2"
  ],
  "metadata": {
    "scope": "domain-only",
    "future_integration": [
      "sandbox_module",
      "acp_module"
    ]
  },
  "steps": [
    {
      "id": "req",
      "type": "acp_stage",
      "config": {
        "stage": "req",
        "session_context_key": "pipeline_acp_session_id",
        "prompt_template": "Capture clear domain requirements for: {{ inputs.task }}",
        "workspace_id": "{{ inputs.workspace_id }}",
        "workspace_group_id": "{{ inputs.workspace_group_id }}"
      }
    },
    {
      "id": "plan",
      "type": "acp_stage",
      "config": {
        "stage": "plan",
        "session_context_key": "pipeline_acp_session_id",
        "prompt_template": "Create a practical implementation plan for: {{ inputs.task }}",
        "workspace_id": "{{ inputs.workspace_id }}",
        "workspace_group_id": "{{ inputs.workspace_group_id }}"
      }
    },
    {
      "id": "impl",
      "type": "acp_stage",
      "config": {
        "stage": "impl",
        "session_context_key": "pipeline_acp_session_id",
        "prompt_template": "Implement based on the approved plan for: {{ inputs.task }}",
        "review_counter_key": "impl_review_count",
        "max_review_loops": 3,
        "workspace_id": "{{ inputs.workspace_id }}",
        "workspace_group_id": "{{ inputs.workspace_group_id }}"
      }
    },
    {
      "id": "impl_review",
      "type": "wait_for_approval",
      "config": {
        "instructions": "Review implementation output and approve or reject.",
        "assigned_to_user_id": "{{ inputs.reviewer_user_id }}"
      },
      "on_failure": "plan"
    },
    {
      "id": "done",
      "type": "prompt",
      "config": {
        "template": "L2 ACP pipeline completed for {{ inputs.task }}"
      }
    }
  ]
}
