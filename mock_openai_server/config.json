{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "cors_origins": ["*"],
    "log_requests": true,
    "simulate_errors": false,
    "error_rate": 0.0
  },
  "streaming": {
    "enabled": true,
    "chunk_delay_ms": 50,
    "tokens_per_chunk": 5
  },
  "responses": {
    "chat_completions": {
      "patterns": [
        {
          "match": {
            "model": "gpt-4",
            "content_regex": ".*test.*"
          },
          "response_file": "responses/chat/test_response.json",
          "priority": 10
        },
        {
          "match": {
            "system_prompt": "You are a helpful assistant"
          },
          "response_file": "responses/chat/default.json",
          "priority": 5
        }
      ],
      "default": "responses/chat/default.json"
    },
    "embeddings": {
      "default": "responses/embeddings/default.json"
    },
    "completions": {
      "default": "responses/chat/default.json"
    }
  },
  "models": [
    {
      "id": "gpt-4",
      "object": "model",
      "owned_by": "openai"
    },
    {
      "id": "gpt-4-turbo",
      "object": "model",
      "owned_by": "openai"
    },
    {
      "id": "gpt-3.5-turbo",
      "object": "model",
      "owned_by": "openai"
    },
    {
      "id": "text-embedding-ada-002",
      "object": "model",
      "owned_by": "openai"
    },
    {
      "id": "text-embedding-3-small",
      "object": "model",
      "owned_by": "openai"
    },
    {
      "id": "text-embedding-3-large",
      "object": "model",
      "owned_by": "openai"
    }
  ]
}