# ================================================
# AuthNZ Module Environment Configuration Template
# ================================================
# Copy this file to .env and configure for your deployment
# SECURITY WARNING: Never commit the actual .env file to version control!

# ================================================
# AUTHENTICATION MODE
# ================================================
# Options: single_user, multi_user
AUTH_MODE=multi_user

# ================================================
# DATABASE CONFIGURATION
# ================================================
# For PostgreSQL (recommended for multi-user production):
# DATABASE_URL=postgresql://username:password@localhost:5432/tldw_db

# For SQLite (development or single-user):
DATABASE_URL=sqlite:///./Databases/users.db

# Database connection pool settings
DATABASE_POOL_MIN_SIZE=5
DATABASE_POOL_MAX_SIZE=20
DATABASE_MAX_QUERIES=50000
DATABASE_MAX_INACTIVE_CONNECTION_LIFETIME=300

# ================================================
# JWT CONFIGURATION (Multi-User Mode)
# ================================================
# REQUIRED: Generate a secure random key (minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY_MIN_32_CHARS

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ================================================
# SINGLE-USER MODE CONFIGURATION
# ================================================
# API key for single-user mode (auto-generated if not set)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SINGLE_USER_API_KEY=CHANGE_ME_TO_SECURE_API_KEY

# ================================================
# ENCRYPTION KEYS
# ================================================
# Session token encryption key (auto-generated from JWT secret if not set)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# API key pepper for additional hashing security (optional but recommended)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_PEPPER=

# ================================================
# REDIS CONFIGURATION (Optional)
# ================================================
# Redis for session caching and rate limiting (improves performance)
# REDIS_URL=redis://localhost:6379/0
# REDIS_MAX_CONNECTIONS=50

# ================================================
# SECURITY SETTINGS
# ================================================
# Registration settings
ENABLE_REGISTRATION=false
REQUIRE_REGISTRATION_CODE=true
REGISTRATION_CODE_DEFAULT_EXPIRY_DAYS=7
REGISTRATION_CODE_DEFAULT_MAX_USES=1

# Password requirements
PASSWORD_MIN_LENGTH=10
ARGON2_MEMORY_COST=32768
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Login security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
SERVICE_ACCOUNT_RATE_LIMIT=1000

# Session security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_CLEANUP_INTERVAL_HOURS=1

# ================================================
# STORAGE SETTINGS
# ================================================
# User data paths
USER_DATA_BASE_PATH=./user_databases
CHROMADB_BASE_PATH=./chromadb_data

# Default user quotas
DEFAULT_STORAGE_QUOTA_MB=5120
DEFAULT_USER_ROLE=user

# ================================================
# MONITORING & LOGGING
# ================================================
# Health checks and metrics
ENABLE_HEALTH_CHECK=true
ENABLE_METRICS=true
METRICS_PORT=9090

# Data retention policies
AUDIT_LOG_RETENTION_DAYS=180
PASSWORD_HISTORY_RETENTION_COUNT=5
SESSION_LOG_RETENTION_DAYS=90

# ================================================
# DEVELOPMENT SETTINGS
# ================================================
# WARNING: Only enable these in development!
# ALLOW_JWT_SECRET_FILE=false  # Never enable in production
# DEBUG_MODE=false              # Verbose logging

# ================================================
# PRODUCTION CHECKLIST
# ================================================
# Before deploying to production, ensure:
# [ ] All CHANGE_ME values have been replaced with secure values
# [ ] JWT_SECRET_KEY is at least 32 characters of random data
# [ ] SINGLE_USER_API_KEY is set (for single-user mode)
# [ ] DATABASE_URL points to production database
# [ ] SESSION_COOKIE_SECURE=true (requires HTTPS)
# [ ] ENABLE_REGISTRATION is set appropriately
# [ ] Redis is configured for better performance (optional)
# [ ] This file is NOT committed to version control
# [ ] Backup strategy is in place for databases
# [ ] Monitoring and alerting are configured

# ================================================
# QUICK START COMMANDS
# ================================================
# 1. Copy this template:
#    cp .env.authnz.template .env
#
# 2. Generate secure keys:
#    python -c "import secrets; print('JWT_SECRET_KEY=' + secrets.token_urlsafe(32))"
#    python -c "import secrets; print('SINGLE_USER_API_KEY=' + secrets.token_urlsafe(32))"
#    python -c "from cryptography.fernet import Fernet; print('SESSION_ENCRYPTION_KEY=' + Fernet.generate_key().decode())"
#
# 3. Run database migrations:
#    python -m tldw_Server_API.app.core.AuthNZ.run_migrations
#
# 4. Initialize AuthNZ:
#    python -m tldw_Server_API.app.core.AuthNZ.initialize
#
# 5. Start the application:
#    python -m uvicorn tldw_Server_API.app.main:app --reload