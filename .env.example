# User Registration System Environment Variables
# Copy this file to .env and update with your actual values

# ===== Authentication Mode =====
# Options: single_user, multi_user
AUTH_MODE=single_user

# ===== Database Configuration =====
# For multi-user mode, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/tldw_db
# For single-user mode, use SQLite:
DATABASE_URL=sqlite:///./Databases/users.db

# ===== JWT Configuration (Multi-user mode only) =====
# Leave empty to auto-generate and persist in .jwt_secret file
JWT_SECRET_KEY=
# File to store persistent JWT secret (auto-created if not exists)
JWT_SECRET_FILE=.jwt_secret
# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Redis Configuration (Optional) =====
# For session caching and rate limiting optimization
# Leave empty to use database-only mode
REDIS_URL=

# ===== Security Settings =====
# Password requirements
PASSWORD_MIN_LENGTH=10
ARGON2_MEMORY_COST=32768
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Account security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ===== Registration Settings =====
ENABLE_REGISTRATION=false
REQUIRE_REGISTRATION_CODE=true
DEFAULT_USER_ROLE=user
DEFAULT_STORAGE_QUOTA_MB=5120
REGISTRATION_CODE_DEFAULT_EXPIRY_DAYS=7
REGISTRATION_CODE_DEFAULT_MAX_USES=1
MAX_BATCH_REGISTRATION_CODES=100

# ===== Rate Limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ===== Storage Settings =====
USER_DATA_BASE_PATH=./user_databases
CHROMADB_BASE_PATH=./chromadb_data

# ===== Monitoring =====
ENABLE_HEALTH_CHECK=true
ENABLE_METRICS=true
METRICS_PORT=9090
SESSION_CLEANUP_INTERVAL_HOURS=1

# ===== Data Retention =====
AUDIT_LOG_RETENTION_DAYS=180
PASSWORD_HISTORY_RETENTION_COUNT=5
SESSION_LOG_RETENTION_DAYS=90

# ===== Single-User Mode Settings =====
# API key for single-user mode authentication
SINGLE_USER_API_KEY=your-secure-api-key-here
SINGLE_USER_FIXED_ID=1

# ===== CORS Settings =====
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1,http://127.0.0.1:8080

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs
LOG_ROTATION_SIZE=10MB
LOG_RETENTION_DAYS=30