{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "uid": "tldw-resource-governor",
  "title": "tldw - Resource Governor",
  "tags": ["tldw", "resource-governor"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Decision Rate (decisions/s)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rg_decisions_total[5m]))",
          "legendFormat": "decisions/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Denial Rate (denials/s)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rg_denials_total[5m]))",
          "legendFormat": "denials/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } }
      }
    },
    {
      "type": "stat",
      "title": "Active Concurrency Leases",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rg_concurrency_active)",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } }
      }
    },
    {
      "type": "timeseries",
      "title": "Decisions Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rg_decisions_total[5m])) by (category)",
          "legendFormat": "{{ category }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Denials Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rg_denials_total[5m])) by (scope)",
          "legendFormat": "{{ scope }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Active Concurrency Leases Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rg_concurrency_active",
          "legendFormat": "{{ instance }}"
        }
      ]
    }
  ]
}
