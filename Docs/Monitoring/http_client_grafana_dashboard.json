{
  "title": "HTTP Client Overview",
  "uid": "http-client-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "http",
    "client",
    "egress"
  ],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests / s",
      "targets": [
        {
          "expr": "sum(rate(http_client_requests_total[5m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95 (s)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retries / s",
      "targets": [
        {
          "expr": "sum(rate(http_client_retries_total[5m]))",
          "legendFormat": "retries/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Egress Denials / s",
      "targets": [
        {
          "expr": "sum by (reason) (rate(http_client_egress_denials_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    }
  ]
}
