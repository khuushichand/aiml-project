{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tldw.ai/embeddings/v1.json",
  "title": "tldw.embeddings.v1 envelope",
  "type": "object",
  "required": ["job_id", "user_id", "media_id"],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "media_id": {
      "type": "integer"
    },
    "msg_schema": {
      "type": "string",
      "const": "tldw.embeddings.v1"
    },
    "msg_version": {
      "type": "integer",
      "const": 1
    },
    "schema_url": {
      "type": "string",
      "const": "https://schemas.tldw.ai/embeddings/v1.json"
    }
  },
  "additionalProperties": true
}
