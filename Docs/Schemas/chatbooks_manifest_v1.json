{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tldw.ai/chatbooks/manifest/v1.json",
  "title": "Chatbooks manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "name",
    "description",
    "author",
    "created_at",
    "updated_at",
    "export_id",
    "content_items",
    "relationships",
    "configuration",
    "statistics",
    "metadata",
    "user_info"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "export_id": {
      "type": ["string", "null"]
    },
    "content_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "title",
          "description",
          "created_at",
          "updated_at",
          "tags",
          "metadata",
          "file_path",
          "checksum"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "conversation",
              "note",
              "character",
              "media",
              "embedding",
              "prompt",
              "evaluation",
              "world_book",
              "dictionary",
              "generated_document"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": ["string", "null"]
          },
          "created_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "updated_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "file_path": {
            "type": ["string", "null"]
          },
          "checksum": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "target_id",
          "relationship_type",
          "metadata"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "relationship_type": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_media",
        "include_embeddings",
        "include_generated_content",
        "media_quality",
        "max_file_size_mb"
      ],
      "properties": {
        "include_media": {
          "type": "boolean"
        },
        "include_embeddings": {
          "type": "boolean"
        },
        "include_generated_content": {
          "type": "boolean"
        },
        "media_quality": {
          "type": "string",
          "enum": [
            "thumbnail",
            "compressed",
            "original"
          ]
        },
        "max_file_size_mb": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_conversations",
        "total_notes",
        "total_characters",
        "total_media_items",
        "total_prompts",
        "total_evaluations",
        "total_embeddings",
        "total_world_books",
        "total_dictionaries",
        "total_documents",
        "total_size_bytes"
      ],
      "properties": {
        "total_conversations": {
          "type": "integer",
          "minimum": 0
        },
        "total_notes": {
          "type": "integer",
          "minimum": 0
        },
        "total_characters": {
          "type": "integer",
          "minimum": 0
        },
        "total_media_items": {
          "type": "integer",
          "minimum": 0
        },
        "total_prompts": {
          "type": "integer",
          "minimum": 0
        },
        "total_evaluations": {
          "type": "integer",
          "minimum": 0
        },
        "total_embeddings": {
          "type": "integer",
          "minimum": 0
        },
        "total_world_books": {
          "type": "integer",
          "minimum": 0
        },
        "total_dictionaries": {
          "type": "integer",
          "minimum": 0
        },
        "total_documents": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "tags",
        "categories",
        "language",
        "license"
      ],
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "language": {
          "type": "string"
        },
        "license": {
          "type": ["string", "null"]
        },
        "binary_limits": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": true
    },
    "user_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_id"
      ],
      "properties": {
        "user_id": {
          "type": ["string", "null"]
        }
      }
    },
    "truncation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "evaluations": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "truncated": {
              "type": "boolean"
            },
            "max_rows": {
              "type": "integer",
              "minimum": 0
            },
            "continuations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
