exports[`ReviewTab create CTA visibility > matches baseline snapshot for active review state 2`] = `
<div
  class="ant-card ant-card-bordered css-dev-only-do-not-override-3uaqrl css-var-root"
  data-testid="flashcards-review-active-card"
>
  <div
    class="ant-card-body"
  >
    <div
      class="flex flex-col gap-3"
    >
      <div>
        <div
          class="flex flex-wrap items-center gap-2"
        >
          <span
            class="ant-tag ant-tag-filled css-dev-only-do-not-override-3uaqrl css-var-root"
          >
            Standard
          </span>
          <button
            aria-label="Edit card (E)"
            class="ant-btn css-dev-only-do-not-override-3uaqrl css-var-root ant-btn-default ant-btn-color-default ant-btn-variant-outlined ant-btn-sm"
            data-testid="flashcards-review-edit-card"
            type="button"
          >
            <span>
              Edit
            </span>
          </button>
        </div>
      </div>
      <div>
        <h5
          class="ant-typography !mb-2 css-dev-only-do-not-override-3uaqrl css-var-root"
        >
          Front
        </h5>
        <div
          class="rounded border border-border bg-surface p-3 text-sm text-text"
        >
          <div
            class="whitespace-pre-wrap"
          >
            Question snapshot
          </div>
        </div>
      </div>
      <div
        class="mt-2 flex flex-col gap-3"
      >
        <div
          class="flex flex-col gap-2"
        >
          <button
            aria-label="Show answer (Space)"
            class="ant-btn css-dev-only-do-not-override-3uaqrl css-var-root ant-btn-primary ant-btn-color-primary ant-btn-variant-solid"
            data-testid="flashcards-review-show-answer"
            type="button"
          >
            <span>
              Show Answer
            </span>
          </button>
          <div
            class="flex flex-wrap items-center gap-2"
            data-testid="flashcards-review-shortcut-chips-question"
          >
            <span
              class="ant-tag ant-tag-filled !m-0 css-dev-only-do-not-override-3uaqrl css-var-root"
            >
              Space Flip
            </span>
            <span
              class="ant-tag ant-tag-filled !m-0 css-dev-only-do-not-override-3uaqrl css-var-root"
            >
              E Edit
            </span>
            <button
              class="ant-btn css-dev-only-do-not-override-3uaqrl css-var-root ant-btn-link ant-btn-color-link ant-btn-variant-link ant-btn-sm !h-auto !px-0 text-xs"
              data-testid="flashcards-review-shortcut-hints-toggle"
              type="button"
            >
              <span>
                Compact hints
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

