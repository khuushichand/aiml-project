{
  "name": "tldw-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "node scripts/build-with-profile.mjs --bundler=turbopack && node scripts/verify-shared-token-sync.mjs --dir .next",
    "build:prod": "cross-env TLDW_BUILD_PROFILE=production node scripts/build-with-profile.mjs --bundler=turbopack && node scripts/verify-shared-token-sync.mjs --dir .next",
    "build:dev": "cross-env TLDW_BUILD_PROFILE=development node scripts/build-with-profile.mjs --bundler=turbopack && node scripts/verify-shared-token-sync.mjs --dir .next",
    "compile": "node scripts/build-with-profile.mjs --bundler=webpack && node scripts/verify-shared-token-sync.mjs --dir .next",
    "compile:prod": "cross-env TLDW_BUILD_PROFILE=production node scripts/build-with-profile.mjs --bundler=webpack && node scripts/verify-shared-token-sync.mjs --dir .next",
    "compile:dev": "cross-env TLDW_BUILD_PROFILE=development node scripts/build-with-profile.mjs --bundler=webpack && node scripts/verify-shared-token-sync.mjs --dir .next",
    "check:token-sync": "node scripts/verify-shared-token-sync.mjs --dir .next",
    "start": "next start",
    "smoke": "node scripts/smoke.mjs",
    "e2e:login": "node scripts/playwright-login.mjs",
    "e2e:pw": "playwright test",
    "e2e:hosted": "NEXT_PUBLIC_TLDW_DEPLOYMENT_MODE=hosted TLDW_WEB_CMD='NEXT_PUBLIC_TLDW_DEPLOYMENT_MODE=hosted bun run dev -- -p 8080' playwright test e2e/hosted/launch-funnel.spec.ts e2e/hosted/account-billing.spec.ts --reporter=line",
    "e2e:hosted:staging": "TLDW_WEB_AUTOSTART=false NEXT_PUBLIC_TLDW_DEPLOYMENT_MODE=hosted TLDW_WEB_URL=${TLDW_STAGING_BASE_URL:?Set TLDW_STAGING_BASE_URL} playwright test e2e/hosted/staging-smoke.spec.ts --reporter=line",
    "e2e:chat-queued-requests": "playwright test e2e/workflows/chat-queued-requests.spec.ts --reporter=line",
    "e2e:family-guardrails": "playwright test e2e/workflows/family-guardrails-wizard.spec.ts --reporter=line",
    "e2e:onboarding": "playwright test e2e/workflows/onboarding-ingestion-first.spec.ts --reporter=line",
    "e2e:workspace-playground:parity": "playwright test e2e/workflows/workspace-playground.parity.spec.ts --reporter=line",
    "e2e:workspace-playground:real": "playwright test e2e/workflows/workspace-playground.real-backend.spec.ts --reporter=line",
    "e2e:smoke": "playwright test e2e/smoke/all-pages.spec.ts --reporter=list",
    "e2e:smoke:all-pages:gate": "playwright test e2e/smoke/all-pages.spec.ts --reporter=line --grep \"Smoke Tests - All Pages\" --workers=1 --global-timeout=1800000",
    "e2e:smoke:stage4": "playwright test e2e/smoke/stage4-axe-high-risk-routes.spec.ts --reporter=line",
    "e2e:smoke:stage5": "playwright test e2e/smoke/stage5-release-gate.spec.ts --reporter=line --workers=1",
    "e2e:smoke:interaction:stage1": "playwright test e2e/smoke/stage6-interaction-stage1.spec.ts --reporter=line",
    "e2e:smoke:interaction:stage2": "playwright test e2e/smoke/stage6-interaction-stage2.spec.ts --reporter=line",
    "e2e:smoke:interaction": "playwright test e2e/smoke/stage6-interaction-stage1.spec.ts e2e/smoke/stage6-interaction-stage2.spec.ts --reporter=line",
    "e2e:smoke:audio": "playwright test e2e/smoke/stage7-audio-regression.spec.ts --reporter=line",
    "e2e:smoke:html": "playwright test e2e/smoke/all-pages.spec.ts --reporter=html",
    "e2e:smoke:chat": "playwright test e2e/smoke/all-pages.spec.ts --grep 'Chat'",
    "e2e:smoke:settings": "playwright test e2e/smoke/all-pages.spec.ts --grep 'Settings'",
    "review:interactive": "npx tsx e2e/interactive-review.ts",
    "review:session": "npx tsx e2e/interactive-review.ts --session",
    "review:resume": "npx tsx e2e/interactive-review.ts --resume",
    "review:parallel": "playwright test e2e/review/parallel-review.spec.ts --reporter=list",
    "review:parallel:session": "playwright test e2e/review/parallel-review.spec.ts --grep 'Session'",
    "review:parallel:category": "playwright test e2e/review/parallel-review.spec.ts --grep 'Category'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:extension": "vitest -c vitest.extension.config.ts",
    "test:characters-harness": "vitest run ../packages/ui/src/components/Option/Characters/__tests__/Manager.first-use.test.tsx ../packages/ui/src/components/Option/Characters/__tests__/CharacterGalleryCard.test.tsx ../packages/ui/src/components/Option/Characters/__tests__/search-utils.test.ts",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "bash ../../Helper_Scripts/run-frontend-integration.sh",
    "e2e:tier1": "playwright test --project=tier-1",
    "e2e:tier2": "playwright test --project=tier-2",
    "e2e:tier3": "playwright test --project=tier-3",
    "e2e:tier4": "playwright test --project=tier-4",
    "e2e:tier5": "playwright test --project=tier-5",
    "e2e:journeys": "playwright test --project=journeys",
    "e2e:critical": "playwright test --project=tier-1 --project=journeys",
    "e2e:features": "playwright test --project=tier-2 --project=tier-3",
    "e2e:admin": "playwright test --project=tier-4 --project=tier-5",
    "e2e:all-tiers": "playwright test --project=tier-1 --project=tier-2 --project=tier-3 --project=tier-4 --project=tier-5 --project=journeys"
  },
  "dependencies": {
    "@sentry/nextjs": "^9.27.0",
    "@ant-design/cssinjs": "^2.0.3",
    "@ant-design/icons": "^5.5.0",
    "@dnd-kit/abstract": "^0.1.21",
    "@dnd-kit/dom": "^0.1.21",
    "@dnd-kit/helpers": "^0.1.21",
    "@dnd-kit/react": "^0.1.21",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.6.0",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-virtual": "^3.13.18",
    "@tiptap/core": "^3.22.1",
    "@tiptap/extension-character-count": "^3.22.1",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@tldw/ui": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "ajv": "^8.17.1",
    "antd": "^6.2.0",
    "axios": "^1.7.2",
    "buffer": "^6.0.3",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "d3-dsv": "^3.0.1",
    "dayjs": "^1.11.19",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "dompurify": "^3.3.1",
    "epubjs": "^0.3.93",
    "gpt-tokenizer": "^3.4.0",
    "html-to-text": "^9.0.5",
    "html2canvas": "^1.4.1",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-icu": "^2.4.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.11",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "next": "^16.1.3",
    "pa-tesseract.js": "^5.1.1",
    "pdfjs-dist": "^4.10.38",
    "prism-react-renderer": "^2.4.1",
    "property-information": "^7.1.0",
    "pubsub-js": "^1.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-i18next": "^16.5.3",
    "react-icons": "^5.5.0",
    "react-joyride": "^2.9.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-syntax-highlighter": "^16.1.0",
    "react-toastify": "^11.0.5",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-mathjax": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "stream-browserify": "^3.0.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.19",
    "turndown": "^7.2.2",
    "unist-util-visit": "^5.0.0",
    "exceljs": "^4.4.0",
