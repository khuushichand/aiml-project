{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@tldw/ui": [
        "../packages/ui/src"
      ],
      "@tldw/ui/*": [
        "../packages/ui/src/*"
      ],
      "@web": [
        "."
      ],
      "@web/*": [
        "./*"
      ],
      "@/*": [
        "../packages/ui/src/*"
      ],
      "~/*": [
        "../packages/ui/src/*"
      ],
      "react-router-dom": [
        "extension/shims/react-router-dom"
      ],
      "@plasmohq/storage": [
        "extension/shims/plasmo-storage"
      ],
      "@plasmohq/storage/hook": [
        "extension/shims/plasmo-storage-hook"
      ],
      "wxt/browser": [
        "extension/shims/wxt-browser"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "vite-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../packages/ui/src/ambient.d.ts",
    "../packages/ui/src/wxt-augment.d.ts"
  ],
  "exclude": [
    "node_modules",
    "components",
    "hooks",
    "lib",
    "models",
    "styles",
    "test",
    "__tests__",
    "types",
    "extension"
  ]
}
