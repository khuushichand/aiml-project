# Production Dockerfile for tldw_server API
# - Multi-stage build keeps compiler/dev packages out of runtime image.
# - Runtime includes ffmpeg + libmagic + PortAudio runtime libs.

FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        python3-dev \
        portaudio19-dev \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy packaging metadata and source to build/install python deps.
COPY pyproject.toml README.md /app/
COPY tldw_Server_API /app/tldw_Server_API

RUN pip install --upgrade pip && \
    pip install --prefix=/install .


FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        libmagic1 \
        libportaudio2 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Bring in installed Python deps from the builder image.
COPY --from=builder /install /usr/local

# Create runtime user up front so content copies can avoid recursive chown.
RUN useradd -m -u 10001 appuser

# Runtime source/docs/scripts expected by server routes and helpers.
COPY --chown=appuser:appuser tldw_Server_API /app/tldw_Server_API
COPY --chown=appuser:appuser apps/tldw-frontend /app/apps/tldw-frontend
COPY --chown=appuser:appuser Docs /app/Docs
COPY --chown=appuser:appuser Helper_Scripts /app/Helper_Scripts
COPY Dockerfiles/entrypoints/tldw-app-first-run.sh /usr/local/bin/tldw-app-first-run

# Create writable runtime DB directory without copying host runtime data.
RUN mkdir -p /app/Databases && \
    chown appuser:appuser /app/Databases && \
    chmod +x /usr/local/bin/tldw-app-first-run
USER appuser

ENV PYTHONPATH=/app/tldw_Server_API \
    HOST=0.0.0.0 \
    PORT=8000 \
    UVICORN_WORKERS=4 \
    LOG_LEVEL=info

EXPOSE 8000

# Basic healthcheck using the readiness probe (avoid extra curl dependency).
HEALTHCHECK --interval=30s --timeout=5s --retries=5 CMD python -c "import sys, urllib.request; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/ready', timeout=3).status == 200 else 1)"

ENTRYPOINT ["/usr/local/bin/tldw-app-first-run"]

# Start the server
CMD ["python", "-m", "uvicorn", "tldw_Server_API.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4", "--log-level", "info", "--proxy-headers"]
